<html lang="fr"><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Corporate Finance — Guide VISEA</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&amp;family=DM+Mono:wght@400;500&amp;family=DM+Sans:wght@300;400;500;600&amp;display=swap" rel="stylesheet">
<style>
:root {
  --navy: #0D1B2A;
  --navy-mid: #1A2E42;
  --navy-light: #253D55;
  --gold: #C9A84C;
  --gold-light: #E4C97E;
  --white: #FAFAF8;
  --text: #E8E4DC;
  --muted: #8A96A3;
  --accent: #4ECDC4;
  --green: #6BCB77;
  --red: #FF6B6B;
  --purple: #A78BFA;
  --border: rgba(201,168,76,0.22);
}
* { margin:0; padding:0; box-sizing:border-box; }
body { background: var(--navy); color: var(--text); font-family: 'DM Sans', sans-serif; font-weight: 300; line-height: 1.75; }
a { color: inherit; text-decoration: none; }

/* ── HEADER ─────────────────────────────── */
.header { background: linear-gradient(135deg, #0D1B2A 0%, #162336 60%, #1a2e42 100%); border-bottom: 1px solid var(--border); padding: 3rem 2rem 2.5rem; position: relative; overflow: hidden; }
.header::before { content: ''; position: absolute; top: -80px; right: -80px; width: 360px; height: 360px; border-radius: 50%; background: radial-gradient(circle, rgba(201,168,76,0.07) 0%, transparent 70%); pointer-events: none; }
.header-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(201,168,76,0.1); border: 1px solid var(--border); border-radius: 40px; padding: 5px 16px; font-size: 0.7rem; font-family: 'DM Mono', monospace; letter-spacing: 0.09em; color: var(--gold); text-transform: uppercase; margin-bottom: 1.4rem; }
.header h1 { font-family: 'Playfair Display', serif; font-size: clamp(1.9rem, 5vw, 3.2rem); font-weight: 700; color: var(--white); line-height: 1.15; margin-bottom: 0.9rem; }
.header h1 em { font-style: italic; color: var(--gold); }
.header-sub { font-size: 0.9rem; color: var(--muted); max-width: 580px; }
.header-sub strong { color: var(--gold-light); font-weight: 500; }

/* ── NAV ─────────────────────────────────── */
.tabs-nav { background: var(--navy-mid); border-bottom: 1px solid var(--border); display: flex; overflow-x: auto; scrollbar-width: none; padding: 0 1rem; }
.tabs-nav::-webkit-scrollbar { display: none; }
.tabs-nav a { color: var(--muted); font-size: 0.75rem; font-weight: 500; letter-spacing: 0.05em; text-transform: uppercase; padding: 0.9rem 1rem; border-bottom: 2px solid transparent; white-space: nowrap; transition: color 0.2s, border-color 0.2s; }
.tabs-nav a:hover { color: var(--gold); border-bottom-color: var(--gold); }

/* ── LAYOUT ─────────────────────────────── */
.wrap { max-width: 1080px; margin: 0 auto; padding: 0 1.5rem; }
.section { padding: 2.8rem 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
.sec-head { display: flex; align-items: flex-start; gap: 1.2rem; margin-bottom: 2rem; }
.sec-num { font-family: 'Playfair Display', serif; font-size: 2.8rem; font-weight: 700; color: rgba(201,168,76,0.14); line-height: 1; min-width: 52px; }
.sec-body-head h2 { font-family: 'Playfair Display', serif; font-size: 1.6rem; font-weight: 700; color: var(--white); margin-bottom: 0.25rem; }
.sec-body-head p { font-size: 0.83rem; color: var(--muted); }

.tag { display: inline-block; font-family: 'DM Mono', monospace; font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.1em; padding: 3px 9px; border-radius: 3px; margin-bottom: 0.35rem; }
.tag-green { background: rgba(107,203,119,0.14); color: var(--green); border: 1px solid rgba(107,203,119,0.28); }
.tag-gold  { background: rgba(201,168,76,0.14); color: var(--gold); border: 1px solid var(--border); }
.tag-red   { background: rgba(255,107,107,0.11); color: var(--red); border: 1px solid rgba(255,107,107,0.24); }

.grid  { display: grid; grid-template-columns: repeat(auto-fit, minmax(290px, 1fr)); gap: 1.1rem; }
.grid-2{ display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 1.1rem; }

.card { background: var(--navy-mid); border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; padding: 1.4rem; transition: border-color 0.2s, transform 0.2s; }
.card:hover { border-color: var(--border); transform: translateY(-2px); }
.card-icon { font-size: 1.4rem; margin-bottom: 0.6rem; display: block; }
.card h3 { font-family: 'Playfair Display', serif; font-size: 1rem; color: var(--white); margin-bottom: 0.55rem; }
.card p, .card li { font-size: 0.85rem; color: var(--muted); line-height: 1.6; }
.card ul { padding-left: 1.15rem; }
.card li { margin-bottom: 0.25rem; }
.card strong { color: var(--text); }

.formula { background: rgba(13,27,42,0.85); border: 1px solid var(--border); border-radius: 9px; padding: 1rem 1.3rem; margin: 0.9rem 0; font-family: 'DM Mono', monospace; font-size: 0.85rem; color: var(--gold-light); position: relative; }
.formula-lbl { position: absolute; top: -9px; left: 10px; background: var(--navy-mid); font-size: 0.6rem; padding: 1px 7px; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; border: 1px solid var(--border); border-radius: 3px; }

.table-wrap { overflow-x: auto; border-radius: 10px; border: 1px solid rgba(255,255,255,0.06); margin: 1.4rem 0; }
table { width: 100%; border-collapse: collapse; }
th { background: var(--navy-light); color: var(--gold); font-family: 'DM Mono', monospace; font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.08em; padding: 0.8rem 1.1rem; text-align: left; border-bottom: 1px solid var(--border); }
td { padding: 0.8rem 1.1rem; font-size: 0.83rem; color: var(--muted); border-bottom: 1px solid rgba(255,255,255,0.04); vertical-align: top; }
tr:last-child td { border-bottom: none; }
tr:hover td { background: rgba(201,168,76,0.03); color: var(--text); }
td:first-child { color: var(--white); font-weight: 500; }

.callout { border-radius: 0 8px 8px 0; padding: 1rem 1.3rem; margin: 1.2rem 0; font-size: 0.86rem; line-height: 1.65; }
.callout-accent { background: rgba(78,205,196,0.07); border-left: 3px solid var(--accent); }
.callout-green  { background: rgba(107,203,119,0.07); border-left: 3px solid var(--green); }
.callout-red    { background: rgba(255,107,107,0.07); border-left: 3px solid var(--red); }
.callout-gold   { background: rgba(201,168,76,0.07); border-left: 3px solid var(--gold); }
.callout-purple { background: rgba(167,139,250,0.07); border-left: 3px solid var(--purple); }
.callout strong { font-weight: 600; }
.callout-accent strong { color: var(--accent); }
.callout-green  strong { color: var(--green); }
.callout-red    strong { color: var(--red); }
.callout-gold   strong { color: var(--gold); }
.callout-purple strong { color: var(--purple); }

/* ── VISEA BOX ─────────────────────────── */
.visea-box { background: linear-gradient(135deg, rgba(201,168,76,0.07), rgba(78,205,196,0.04)); border: 1px solid var(--border); border-left: 4px solid var(--gold); border-radius: 12px; padding: 1.8rem; margin: 2rem 0; }
.visea-box h2 { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: var(--gold); margin-bottom: 0.8rem; }
.meta-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: 0.9rem; margin-top: 1.1rem; }
.meta-card { background: rgba(13,27,42,0.55); border: 1px solid var(--border); border-radius: 8px; padding: 0.9rem 1.1rem; }
.meta-title { font-size: 0.68rem; font-family: 'DM Mono', monospace; color: var(--gold); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.35rem; }
.meta-card p { font-size: 0.82rem; color: var(--muted); line-height: 1.5; }

/* ── EXPLAINER DETAILS (néophyte) ────────
   Bouton "🔍 Comprendre en détail" à l'intérieur d'une carte
*/
.explainer { margin-top: 1rem; }

.explainer > summary {
  cursor: pointer;
  list-style: none;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(167,139,250,0.1);
  border: 1px solid rgba(167,139,250,0.28);
  border-radius: 20px;
  padding: 5px 14px;
  font-size: 0.76rem;
  font-weight: 500;
  color: var(--purple);
  letter-spacing: 0.02em;
  transition: background 0.2s;
  user-select: none;
}
.explainer > summary::-webkit-details-marker { display: none; }
.explainer > summary:hover { background: rgba(167,139,250,0.18); }
.explainer[open] > summary { background: rgba(167,139,250,0.2); }

.explainer-body {
  background: rgba(167,139,250,0.05);
  border: 1px solid rgba(167,139,250,0.18);
  border-radius: 10px;
  padding: 1.2rem 1.3rem;
  margin-top: 0.8rem;
  font-size: 0.84rem;
  color: var(--text);
  line-height: 1.7;
}
.explainer-body h4 {
  font-family: 'Playfair Display', serif;
  font-size: 0.95rem;
  color: var(--purple);
  margin-bottom: 0.6rem;
}
.explainer-body .analogy {
  background: rgba(167,139,250,0.1);
  border-radius: 8px;
  padding: 0.8rem 1rem;
  margin: 0.8rem 0;
  font-style: italic;
  color: var(--gold-light);
  font-size: 0.83rem;
}
.explainer-body .analogy::before { content: '💡 Analogie : '; font-style: normal; color: var(--gold); font-weight: 600; }
.explainer-body .ex-table { width: 100%; border-collapse: collapse; margin: 0.8rem 0; font-size: 0.82rem; }
.explainer-body .ex-table th { background: rgba(167,139,250,0.15); color: var(--purple); font-size: 0.68rem; padding: 0.5rem 0.8rem; text-align: left; font-family: 'DM Mono', monospace; letter-spacing: 0.06em; text-transform: uppercase; border-bottom: 1px solid rgba(167,139,250,0.2); }
.explainer-body .ex-table td { padding: 0.5rem 0.8rem; color: var(--muted); border-bottom: 1px solid rgba(255,255,255,0.04); }
.explainer-body .ex-table td:first-child { color: var(--white); font-weight: 500; }
.explainer-body .ex-table tr:last-child td { border-bottom: none; }
.explainer-body ul { padding-left: 1.2rem; margin: 0.5rem 0; }
.explainer-body li { margin-bottom: 0.4rem; color: var(--muted); }
.explainer-body li strong { color: var(--text); }
.explainer-body p { margin-bottom: 0.5rem; color: var(--muted); }
.explainer-body p strong { color: var(--white); }
.mono { font-family: 'DM Mono', monospace; color: var(--gold-light); font-size: 0.8rem; background: rgba(13,27,42,0.6); padding: 0.6rem 0.9rem; border-radius: 6px; display: block; margin: 0.5rem 0; }

/* ── BILAN VISUEL ─────────────────────── */
.bilan-visual {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: rgba(255,255,255,0.06);
  border-radius: 10px;
  overflow: hidden;
  margin: 1rem 0;
  font-size: 0.8rem;
}
.bilan-col { background: rgba(13,27,42,0.8); }
.bilan-header { padding: 0.6rem 1rem; font-family: 'DM Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; text-align: center; font-weight: 500; }
.bilan-header.actif  { background: rgba(78,205,196,0.15); color: var(--accent); }
.bilan-header.passif { background: rgba(201,168,76,0.15); color: var(--gold); }
.bilan-row { padding: 0.45rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.04); display: flex; justify-content: space-between; align-items: center; }
.bilan-row:last-child { border-bottom: none; }
.bilan-row .lbl { color: var(--muted); }
.bilan-row .val { font-family: 'DM Mono', monospace; color: var(--white); font-size: 0.75rem; }
.bilan-row.subtotal { background: rgba(255,255,255,0.03); }
.bilan-row.subtotal .lbl { color: var(--text); font-weight: 500; }
.bilan-row.subtotal .val { color: var(--gold-light); }
.bilan-row.total { background: rgba(201,168,76,0.08); }
.bilan-row.total .lbl { color: var(--gold); font-weight: 600; font-size: 0.82rem; }
.bilan-row.total .val { color: var(--gold); font-weight: 600; }

/* ── QUIZ ──────────────────────────────── */
.quiz-box { background: linear-gradient(135deg, var(--navy-mid), rgba(26,46,66,0.8)); border: 1px solid var(--border); border-radius: 14px; padding: 1.8rem; margin: 1.8rem 0; }
.quiz-box-title { font-family: 'Playfair Display', serif; font-size: 1.15rem; color: var(--gold); margin-bottom: 1.3rem; display: flex; align-items: center; gap: 8px; }

details.quiz-item { background: rgba(13,27,42,0.6); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; margin-bottom: 0.85rem; overflow: hidden; }
details.quiz-item:hover { border-color: rgba(201,168,76,0.3); }
details.quiz-item[open] { border-color: var(--gold); border-left: 3px solid var(--gold); }

details.quiz-item > summary { cursor: pointer; padding: 1.1rem 1.4rem; font-size: 0.89rem; font-weight: 500; color: var(--text); display: flex; align-items: center; gap: 10px; list-style: none; user-select: none; position: relative; }
details.quiz-item > summary::-webkit-details-marker { display: none; }
details.quiz-item > summary::before { content: 'Q'; background: var(--gold); color: var(--navy); font-family: 'DM Mono', monospace; font-size: 0.62rem; font-weight: 700; padding: 2px 6px; border-radius: 3px; flex-shrink: 0; }
details.quiz-item > summary .arrow { margin-left: auto; color: var(--muted); font-size: 0.7rem; transition: transform 0.25s; flex-shrink: 0; }
details.quiz-item[open] > summary .arrow { transform: rotate(180deg); }

.quiz-hint { font-size: 0.72rem; font-style: italic; color: var(--muted); padding: 0 1.4rem 0.6rem 2.8rem; display: block; }
details.quiz-item[open] .quiz-hint { display: none; }

.quiz-answer { padding: 1rem 1.4rem 1.1rem 2.8rem; border-top: 1px solid rgba(255,255,255,0.06); font-size: 0.85rem; color: var(--text); line-height: 1.7; background: rgba(78,205,196,0.04); }
.quiz-answer strong { color: var(--accent); }

/* ── GLOSSAIRE ─────────────────────────── */
.gloss-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(270px, 1fr)); gap: 0.75rem; margin-top: 1rem; }
.gloss { background: var(--navy-mid); border: 1px solid rgba(255,255,255,0.06); border-radius: 8px; padding: 0.9rem 1.1rem; }
.gloss-term { font-family: 'DM Mono', monospace; font-size: 0.75rem; color: var(--gold); font-weight: 500; margin-bottom: 0.35rem; }
.gloss-def { font-size: 0.81rem; color: var(--muted); line-height: 1.5; }

h3.sub { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: var(--white); margin: 2rem 0 1rem; }

footer { text-align: center; padding: 2.5rem 2rem; color: var(--muted); font-size: 0.78rem; border-top: 1px solid var(--border); }
footer strong { color: var(--gold); }

@media (max-width: 580px) {
  .sec-num { font-size: 2rem; min-width: 38px; }
  .grid, .grid-2 { grid-template-columns: 1fr; }
  .bilan-visual { grid-template-columns: 1fr; }
}
</style>
</head>
