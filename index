<div class="section" id="quiz">
  <div class="sec-head">
    <div class="sec-num">06</div>
    <div class="sec-body-head">
      <div class="tag tag-red">Quiz — Simulation Entretien</div>
      <h2>Questions types pour l'entretien VISEA</h2>
      <p>Cliquez sur chaque question pour révéler la réponse attendue</p>
    </div>
